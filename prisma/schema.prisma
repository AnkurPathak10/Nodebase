// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {                                    //Creates the prisma client code which we import
  provider = "prisma-client-js"                       // Generate a JavaScript/TypeScript client
  binaryTargets = ["native", "rhel-openssl-3.0.x"]    // added rhel-openssl-3.0.x for Vercel deployment
}

datasource db {                                 //tells prisma which database to use
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {                                        //Defines a model for the User table
  id            String    @id                         //@id marks this as Primary key
  name          String
  email         String
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())            //@default(now()) Auto-sets to current timestamp
  updatedAt     DateTime  @default(now()) @updatedAt //@updatedAt Auto-updates to current timestamp on update
  sessions      Session[]                                //One-to-many relationship with Session table
  accounts      Account[]                                //One-to-many relationship with Account table
  workflows     Workflow[]                               //One-to-many relationship with Workflow table. The [] makes it a list/array
  credentials   Credential[]                             //One-to-many relationship with Credential table

  @@unique([email])                                     //@unique marks this as unique constraint
  @@map("user")                        //Changes the table name in the databaseThe model name in Prisma stays the same
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  @@map("verification")
}

model Credential {
  id String @id @default(cuid())
  name String
  value String
  type CredentialType
  
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  userId String
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  Node Node[]
}

model Workflow {
  id String @id @default(cuid())
  name String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  nodes Node[]
  connections Connection[]
  executions Execution[]

  userId String
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)  // Foreign key pointing to User table
}

enum NodeType{
  INITIAL
  MANUAL_TRIGGER
  HTTP_REQUEST
  GOOGLE_FORM_TRIGGER
  STRIPE_TRIGGER
  ANTHROPIC
  GEMINI
  OPENAI
  DISCORD
  SLACK
}

model Node{
  id String @id @default(cuid())
  workflowId String
  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  
  name String
  type NodeType        //can only be one of the values in the NodeType enum
  position Json
  data Json @default("{}")

  outputConnections Connection[] @relation("FromNode")
  inputConnections Connection[] @relation("ToNode")

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  credentialId String?
  credential Credential? @relation(fields: [credentialId], references: [id], onDelete: SetNull)
}

enum CredentialType {
  OPENAI
  ANTHROPIC
  GEMINI
}

model Connection{
  id String @id @default(cuid())
  workflowId String
  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  
  fromNodeId String                     //This is the actual column in the database that will be created
  fromNode Node @relation("FromNode", fields: [fromNodeId], references: [id], onDelete: Cascade) //This is a virtual field (doesn't exist in the database). Used by Prisma to fetch the related Node. Type is Node (the model it relates to)

  toNodeId String
  toNode Node @relation("ToNode", fields: [toNodeId], references: [id], onDelete: Cascade)

  fromOutput String @default("main")
  toInput String @default("main")

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([fromNodeId, toNodeId, fromOutput, toInput])
}

enum ExecutionStatus {
  RUNNING
  SUCCESS
  FAILED
}

model Execution{
  id String @id @default(cuid())  //cuid() - Generates a unique ID automatically

  workflowId String
  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  status ExecutionStatus @default(RUNNING)
  error String? @db.Text               //String without @db.Text → VARCHAR(255) in PostgreSQL but String with @db.Text → TEXT (unlimited length) in PostgreSQL
  errorStack String? @db.Text

  startedAt DateTime @default(now())
  completedAt DateTime?

  inngestEventId String @unique

  output Json?
}